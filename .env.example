# ============================================================
#  FX OD Management System – Environment Variables
#  Copy this file to .env and fill in real values.
# ============================================================

# -----------------------------------------------------------
# Backend API base URL
# In development: http://localhost:5000/api
# In production : https://your-server.com/api
# -----------------------------------------------------------
VITE_API_BASE_URL=http://localhost:5000/api

# -----------------------------------------------------------
# App mode: "mock" (local demo data) | "live" (real backend)
# Change to "live" when backend is ready
# -----------------------------------------------------------
VITE_APP_MODE=mock

# -----------------------------------------------------------
# Google OAuth Client ID (when real OAuth is configured)
# -----------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# -----------------------------------------------------------
# App info
# -----------------------------------------------------------
VITE_APP_NAME=FX OD Management System
VITE_APP_VERSION=2.0.0
